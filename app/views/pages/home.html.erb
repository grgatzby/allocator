<div class="container py-4">
  <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4">
    <div>
      <h1 class="mb-1">Allocator - Ingestion Dashboard</h1>
      <p class="text-muted mb-0">Pilotez les imports macro (World Bank, IMF, Eurostat, OECD).</p>
    </div>
    <div class="mt-3 mt-md-0">
      <% if user_signed_in? %>
        <span class="badge bg-success">Connecte</span>
      <% else %>
        <span class="badge bg-secondary">Visiteur</span>
      <% end %>
    </div>
  </div>

  <% if notice.present? %>
    <div class="alert alert-success"><%= notice %></div>
  <% end %>
  <% if alert.present? %>
    <div class="alert alert-danger"><%= alert %></div>
  <% end %>

  <div class="row g-3 mb-4">
    <div class="col-6 col-lg-3">
      <div class="card h-100">
        <div class="card-body">
          <div class="text-muted small">Countries</div>
          <div class="h3 mb-0"><%= @stats[:countries] %></div>
        </div>
      </div>
    </div>
    <div class="col-6 col-lg-3">
      <div class="card h-100">
        <div class="card-body">
          <div class="text-muted small">Indicators</div>
          <div class="h3 mb-0"><%= @stats[:indicators] %></div>
        </div>
      </div>
    </div>
    <div class="col-6 col-lg-3">
      <div class="card h-100">
        <div class="card-body">
          <div class="text-muted small">Series</div>
          <div class="h3 mb-0"><%= @stats[:series] %></div>
        </div>
      </div>
    </div>
    <div class="col-6 col-lg-3">
      <div class="card h-100">
        <div class="card-body">
          <div class="text-muted small">Observations</div>
          <div class="h3 mb-0"><%= @stats[:observations] %></div>
        </div>
      </div>
    </div>
  </div>

  <div class="row g-3 mb-4">
    <div class="col-6 col-lg-3">
      <div class="card h-100 border-info">
        <div class="card-body">
          <div class="text-muted small">Inflation series</div>
          <div class="h4 mb-0"><%= @stats[:inflation_series] %></div>
        </div>
      </div>
    </div>
    <div class="col-6 col-lg-3">
      <div class="card h-100 border-info">
        <div class="card-body">
          <div class="text-muted small">Inflation observations</div>
          <div class="h4 mb-0"><%= @stats[:inflation_observations] %></div>
        </div>
      </div>
    </div>
  </div>

  <div class="card mb-4">
    <div class="card-body">
      <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
        <h2 class="h5 mb-0">Lancer une ingestion</h2>
        <div class="d-flex gap-2">
          <%= link_to "Voir les donnees par pays", data_page_path, class: "btn btn-sm btn-outline-secondary" %>
          <%= link_to "Voir analyse", analyse_page_path, class: "btn btn-sm btn-outline-secondary" %>
          <%= link_to "Voir crude oil en or", oil_gold_page_path, class: "btn btn-sm btn-outline-secondary" %>
        </div>
      </div>
      <% if user_signed_in? %>
        <div class="d-flex flex-wrap gap-2">
          <%= button_to "Run all sources", run_ingestion_path(source: "all"), method: :post, class: "btn btn-primary" %>
          <%= button_to "Run World Bank", run_ingestion_path(source: "world_bank"), method: :post, class: "btn btn-outline-primary" %>
          <%= button_to "Run IMF", run_ingestion_path(source: "imf"), method: :post, class: "btn btn-outline-primary" %>
          <%= button_to "Run Eurostat", run_ingestion_path(source: "eurostat"), method: :post, class: "btn btn-outline-primary" %>
          <%= button_to "Run OECD", run_ingestion_path(source: "oecd"), method: :post, class: "btn btn-outline-primary" %>
        </div>
      <% else %>
        <p class="mb-0">Connectez-vous pour lancer une ingestion.</p>
      <% end %>
    </div>
  </div>

  <div class="card">
    <div class="card-body">
      <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
        <h2 class="h5 mb-0">Derniers runs</h2>
        <% if user_signed_in? %>
          <%= button_to "Effacer runs failed / 0-0", cleanup_runs_path, method: :delete, class: "btn btn-sm btn-outline-danger", data: { turbo_confirm: "Supprimer toutes les lignes failed ou 0/0 ?" } %>
        <% end %>
      </div>
      <% if @recent_runs.any? %>
        <div class="table-responsive">
          <table class="table table-sm align-middle mb-0">
            <thead>
              <tr>
                <th>Run #</th>
                <th>Source</th>
                <th>Status</th>
                <th>Started at</th>
                <th>Finished at</th>
                <th>Rows read</th>
                <th>Rows written</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody>
              <% @recent_runs.each do |run| %>
                <tr>
                  <td><%= run.id %></td>
                  <td><%= run.data_source.code %></td>
                  <td>
                    <% badge_class = run.status == "success" ? "bg-success" : (run.status == "failed" ? "bg-danger" : "bg-warning text-dark") %>
                    <span class="badge <%= badge_class %>"><%= run.status %></span>
                  </td>
                  <td><%= run.started_at&.strftime("%Y-%m-%d %H:%M") %></td>
                  <td><%= run.finished_at&.strftime("%Y-%m-%d %H:%M") %></td>
                  <td><%= run.rows_read %></td>
                  <td><%= run.rows_written %></td>
                  <td>
                    <% if user_signed_in? %>
                      <div class="d-flex flex-wrap gap-1">
                        <%= link_to "Voir log", run_log_path(run), class: "btn btn-sm btn-outline-info", target: "_blank", rel: "noopener" %>
                        <% if run.status == "running" %>
                          <%= button_to "Supprimer run", delete_run_path(run), method: :delete, class: "btn btn-sm btn-outline-warning", data: { turbo_confirm: "Supprimer ce run en cours ?" } %>
                        <% else %>
                          <%= button_to "Supprimer donnees run", delete_run_data_path(run), method: :delete, class: "btn btn-sm btn-outline-secondary", data: { turbo_confirm: "Supprimer les observations de ce run ?" } %>
                        <% end %>
                      </div>
                    <% else %>
                      <span class="text-muted small">-</span>
                    <% end %>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% else %>
        <p class="mb-0 text-muted">Aucun run disponible pour le moment.</p>
      <% end %>
    </div>
  </div>
</div>
